<!-- Chart.js -->
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>

<script>
document.addEventListener('DOMContentLoaded', function () {
  const months = @json(array_column($demandData, 'month'));
  const demandActual = @json(array_column($demandData, 'actual'));
  const demandForecast = @json(array_column($demandData, 'forecast'));
  const productMonthly = @json($productMonthly);

  const ctx = document.getElementById('demandChart').getContext('2d');
  const chart = new Chart(ctx, {
    type: 'line',
    data: {
      labels: months,
      datasets: [
        { label: 'Actual', data: demandActual, borderColor: '#10b981', backgroundColor: '#10b98122', tension: 0.4, fill: true },
        { label: 'Forecast', data: demandForecast, borderColor: '#3b82f6', backgroundColor: '#3b82f622', tension: 0.4, fill: true }
      ]
    },
    options: { responsive: true, plugins: { legend: { position: 'bottom' } } }
  });

  const filterProduct = document.getElementById('filterProduct');
  const historicalRows = Array.from(document.querySelectorAll('#historicalTable tr'));
  const predDemandEl = document.getElementById('predDemand');

  const updateForProduct = (sku) => {
    if (sku === 'all') {
      chart.data.datasets[0].data = demandActual;
      chart.data.datasets[1].data = demandForecast;
      predDemandEl.textContent = '12,450 units';
      historicalRows.forEach(r => r.style.display = '');
    } else if (productMonthly[sku]) {
      chart.data.datasets[0].data = productMonthly[sku];
      chart.data.datasets[1].data = productMonthly[sku].map(v => Math.round(v * 1.08));
      const total = chart.data.datasets[1].data.reduce((a,b)=>a+b,0);
      predDemandEl.textContent = total.toLocaleString() + ' units';
      historicalRows.forEach(r => {
        r.style.display = (r.dataset.sku === sku) ? '' : 'none';
      });
    }
    chart.update();
  };

  filterProduct.addEventListener('change', function () { updateForProduct(this.value); });

  document.getElementById('filterRange').addEventListener('change', function () {
    // For demo: range only affects chart zoom/resolution in future
    // No-op for now
  });
});
</script>

@endsection

